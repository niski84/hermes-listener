# hermes-listener configuration
# Copy to .env and edit. Settings UI at http://localhost:$PORT/ also writes here.

# Port for the web settings UI + /api/health
PORT=9120

# Where transcripts get written. Most agents (Hermes, Claude Code, etc.)
# look at an Obsidian vault — point this at the vault root and we'll
# create a `listener/` subfolder inside it. Daily file format:
#   $VAULT_PATH/listener/YYYY-MM-DD.md
VAULT_PATH=~/Documents/vault

# --- Speech-to-text ---
# Local whisper.cpp HTTP server (run via scripts/start-whisper.sh).
# Or use OpenAI/Groq whisper for cloud STT.
WHISPER_URL=http://localhost:9000
# WHISPER_PROVIDER=local      # local | openai | groq
# WHISPER_API_KEY=             # required when provider != local

# --- Wake-word (optional) ---
# When unset, the listener transcribes everything within VAD gates.
# When set, only utterances after a wake-word trigger are transcribed.
# WAKE_WORD_URL=http://localhost:9201
# WAKE_WORDS=computer,hermes

# --- Speaker filter (optional) ---
# ECAPA voiceprint sidecar. Drops clips that don't match your enrolled
# voiceprint — useful for filtering out family members, TV, podcasts.
# SPEAKER_SIDECAR_URL=http://127.0.0.1:9200
# SPEAKER_MIN_CLIP_DURATION=5     # seconds (clips shorter are passed through)
# SPEAKER_THRESHOLD=0.25          # cosine similarity floor

# --- TV chatter rejection (optional) ---
# Drops clips that match what's currently playing on a Plex client.
# Solves "movie dialogue leaking into transcript."
# PLEX_BASE_URL=http://localhost:32400
# PLEX_TOKEN=

# --- Microphone ---
# ALSA device name. List with: arecord -L
# When unset, uses system default.
# MIC_DEVICE=default

# --- VAD (Voice Activity Detection) ---
# Energy gate in dB below which audio is considered silence.
VAD_THRESHOLD_DB=-30
# Silence gap (seconds) that closes a session.
SESSION_GAP_SECONDS=900
